        <mxCell id="title" value="Stage1 网络结构流程图（Video DiT / LoRA 训练）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="700" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lane_in" value="输入与编码" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="520" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="lane_core" value="主干网络（Cosmos Transformer + LoRA）" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#e8f3ff;strokeColor=#4a90e2;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="720" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="lane_out" value="去噪采样、解码与训练信号" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#eaf7ea;strokeColor=#59a14f;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1330" y="80" width="560" height="900" as="geometry"/>
        </mxCell>

        <mxCell id="n1" value="输入视频&#xa;video: [B, T, C, H, W]&#xa;（来自 MimicVideoDataset）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="460" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n2" value="维度重排&#xa;[B, T, C, H, W] → [B, C, T, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="460" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n3" value="VAE 编码（冻结）&#xa;z0: [B, C_lat, T_lat, H_lat, W_lat]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="460" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="n4" value="时间切分&#xa;z_cond = z0[:,:,:T_cond]&#xa;z_pred = z0[:,:,T_cond:]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="460" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n5" value="采样噪声与时间步&#xa;eps_v ~ N(0,1), tau_v ~ p(t)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="460" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="n6" value="构造噪声预测目标输入&#xa;z_noisy = (1-tau_v)·z_pred + tau_v·eps_v" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="460" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="n7" value="文本条件&#xa;t5_embedding: [B, L, D_text]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="820" width="460" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="Cosmos Transformer（LoRA 可训练）&#xa;输入: z_cond, z_noisy, tau_v, t5_emb&#xa;输出: raw_output + full_output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90e2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="640" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="full_output 中取预测段&#xa;x0_pred = full_output[:,:,T_cond:]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90e2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="360" width="640" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="Stage1 训练损失&#xa;L = MSE(x0_pred, z_pred)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8ebff;strokeColor=#4a90e2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="470" width="640" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="反向传播（仅 LoRA 参数）&#xa;梯度累加 → clip_grad → optimizer.step" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8ebff;strokeColor=#4a90e2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="580" width="640" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="c5" value="中间表征（用于可视化/验证）&#xa;z_cond + 预测得到的 z_pred_denoised" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90e2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="700" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="o1" value="Euler ODE 采样（验证/测试）&#xa;从 z_noise 迭代到 z_pred_denoised&#xa;num_steps = ode_steps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#59a14f;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1360" y="220" width="500" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="o2" value="拼接 latent&#xa;pred_latents = cat(z_cond, z_pred_denoised)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#59a14f;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1360" y="350" width="500" height="75" as="geometry"/>
