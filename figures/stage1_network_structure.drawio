        <mxCell id="o3" value="VAE 解码（冻结）&#xa;GT: decode(z0)&#xa;Pred: decode(pred_latents)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#59a14f;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1360" y="455" width="500" height="90" as="geometry"/>
