          <mxGeometry x="530" y="335" width="175" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6B7280;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="noise_a" target="action_mlp" parent="1"/>

        <!-- Proprio MLP -->
