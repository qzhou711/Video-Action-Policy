        </mxCell>

        <mxCell id="dec_config" value="&lt;font color=&quot;#6B7280&quot; style=&quot;font-size:11px&quot;&gt;hidden_dim=512 · 8 layers · 8 heads · mlp_ratio=4&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="680" y="540" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- Arrows into decoder -->
