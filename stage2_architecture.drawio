        <!-- Sequence construction -->
        <mxCell id="seq" value="&lt;b&gt;序列拼接 + 位置编码&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;[proprio, action₁, ..., action₁₆] + pos_embed → [B, 17, 512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;fontSize=11;arcSize=12;" vertex="1" parent="1">
