        <!-- Spatial Pooling -->
        <mxCell id="pool" value="&lt;b&gt;Spatial Mean Pooling&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#6B7280&quot;&gt;[B, T·H'·W', 2048] → [B, 5, 2048]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;fontSize=11;arcSize=12;" vertex="1" parent="1">
