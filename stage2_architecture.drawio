        <mxCell id="adaln2" value="&lt;b&gt;AdaLN-Zero&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="738" width="170" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="self_attn" value="&lt;b&gt;Self-Attention&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#991B1B&quot;&gt;Q, K, V ← action tokens · 8 heads&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="732" width="260" height="52" as="geometry"/>
        </mxCell>

        <mxCell id="gate2" value="&lt;b&gt;⊕ Gate&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="740" width="100" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="eb3" style="strokeColor=#EF4444;strokeWidth=1.2;endArrow=blockThin;endFill=1;endSize=5;" edge="1" source="adaln2" target="self_attn" parent="1"/>
        <mxCell id="eb4" style="strokeColor=#EF4444;strokeWidth=1.2;endArrow=blockThin;endFill=1;endSize=5;" edge="1" source="self_attn" target="gate2" parent="1"/>

        <mxCell id="self_label" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#B91C1C&quot;&gt;&lt;b&gt;Self-Attention (action seq)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=right;" vertex="1" parent="1">
          <mxGeometry x="1070" y="745" width="190" height="18" as="geometry"/>
        </mxCell>

        <!-- Block 3: MLP -->
        <mxCell id="blk_mlp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#FECACA;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="830" width="820" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="blk_mlp_num" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#DC2626&quot;&gt;&lt;b&gt;③&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="455" y="833" width="25" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="adaln3" value="&lt;b&gt;AdaLN-Zero&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="855" width="170" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="mlp" value="&lt;b&gt;Feed-Forward MLP&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#991B1B&quot;&gt;512 → 2048 (GELU) → 512&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="850" width="260" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="gate3" value="&lt;b&gt;⊕ Gate&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="857" width="100" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="eb5" style="strokeColor=#EF4444;strokeWidth=1.2;endArrow=blockThin;endFill=1;endSize=5;" edge="1" source="adaln3" target="mlp" parent="1"/>
        <mxCell id="eb6" style="strokeColor=#EF4444;strokeWidth=1.2;endArrow=blockThin;endFill=1;endSize=5;" edge="1" source="mlp" target="gate3" parent="1"/>

        <mxCell id="mlp_label" value="&lt;font style=&quot;font-size:10px&quot; color=&quot;#B91C1C&quot;&gt;&lt;b&gt;FFN (4× expansion)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=right;" vertex="1" parent="1">
          <mxGeometry x="1070" y="862" width="190" height="18" as="geometry"/>
        </mxCell>

        <!-- Output Head -->
        <mxCell id="out_head" value="&lt;b&gt;LayerNorm → Linear(512→7)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#991B1B&quot;&gt;零初始化 · 仅取 action tokens (跳过 proprio)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="570" y="945" width="340" height="42" as="geometry"/>
        </mxCell>

        <!-- ==================== SECTION: LOSS ==================== -->

        <!-- v_pred output -->
        <mxCell id="v_pred" value="&lt;b&gt;v&lt;sub&gt;pred&lt;/sub&gt;&lt;/b&gt;  &lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;[B, 16, 7]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#D1D5DB;fontSize=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="530" y="1040" width="180" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="e_out" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6B7280;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="out_head" target="v_pred" parent="1"/>

        <!-- v_target -->
        <mxCell id="v_tgt" value="&lt;b&gt;v&lt;sub&gt;target&lt;/sub&gt;&lt;/b&gt;  &lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;= ε&lt;sub&gt;a&lt;/sub&gt; − a₀&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#D1D5DB;fontSize=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="780" y="1040" width="170" height="38" as="geometry"/>
        </mxCell>

        <!-- Loss -->
        <mxCell id="loss" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;ℒ = MSE( v&lt;sub&gt;pred&lt;/sub&gt; , v&lt;sub&gt;target&lt;/sub&gt; )&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;arcSize=12;fontColor=#991B1B;" vertex="1" parent="1">
          <mxGeometry x="560" y="1120" width="340" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="el1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="v_pred" target="loss" parent="1"/>
        <mxCell id="el2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DC2626;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="v_tgt" target="loss" parent="1"/>

        <!-- Optimizer -->
        <mxCell id="optim" value="&lt;b&gt;AdamW&lt;/b&gt;  &lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;lr=1e-4 · warmup 1K → linear decay · grad_clip=10 · 仅更新 Decoder 参数&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="1200" width="480" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="eopt" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F59E0B;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="loss" target="optim" parent="1"/>

        <!-- Backward arrow annotation -->
        <mxCell id="bwd_arrow" value="" style="endArrow=blockThin;endFill=1;dashed=1;strokeColor=#EF4444;strokeWidth=1.5;endSize=6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="1200" as="sourcePoint"/>
            <mxPoint x="420" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="bwd_label" value="&lt;font color=&quot;#EF4444&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;backward&lt;br&gt;(梯度仅&lt;br&gt;流过 Decoder)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="370" y="880" width="55" height="50" as="geometry"/>
        </mxCell>

        <!-- No gradient annotation on backbone -->
        <mxCell id="no_grad" value="&lt;font color=&quot;#3B82F6&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;无梯度&lt;br&gt;∅&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="420" width="40" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
