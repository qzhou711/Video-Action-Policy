        <mxCell id="ea4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6B7280;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="action_mlp" target="seq" parent="1"/>
        <mxCell id="ea5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6B7280;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;" edge="1" source="proprio_mlp" target="seq" parent="1"/>

        <!-- Timestep Embedding -->
        <mxCell id="ts_embed" value="&lt;b&gt;Bilinear-Affine 时间步嵌入&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#991B1B&quot;&gt;Sin(τ&lt;sub&gt;v&lt;/sub&gt;)→MLP ⊙ Sin(τ&lt;sub&gt;a&lt;/sub&gt;)→MLP → SiLU→Linear → cond [B, 512]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="970" y="330" width="370" height="48" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
