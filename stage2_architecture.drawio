        <!-- τ_a sampling -->
        <mxCell id="tau_a" value="&lt;b&gt;τ&lt;sub&gt;a&lt;/sub&gt;&lt;/b&gt; ~ U^(1/0.999)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#6B7280&quot;&gt;Pi0-style 偏重高噪声&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#8B5CF6;fontSize=10;arcSize=12;" vertex="1" parent="1">
