        <mxCell id="dec_title" value="&lt;font style=&quot;font-size:16px&quot; color=&quot;#DC2626&quot;&gt;&lt;b&gt;ActionDecoderDiT&lt;/b&gt;  🔥  &lt;font style=&quot;font-size:12px&quot;&gt;~67M 参数&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
