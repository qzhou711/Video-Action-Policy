        <mxCell id="h_video" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;h&lt;sub&gt;video&lt;/sub&gt;&lt;/b&gt;&lt;/font&gt;  &lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;[B, 5, 2048] · detached&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#F97316;fontSize=12;arcSize=12;fontStyle=1;" vertex="1" parent="1">
