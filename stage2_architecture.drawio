        <mxCell id="e_ts" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#EF4444;strokeWidth=1.5;endArrow=blockThin;endFill=1;endSize=6;entryX=1;entryY=0.15;" edge="1" source="ts_embed" target="dec_box" parent="1"/>

        <!-- h_video → decoder (big orange arrow) -->
        <mxCell id="e_hv" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F97316;strokeWidth=3;endArrow=blockThin;endFill=1;endSize=8;entryX=0;entryY=0.5;" edge="1" source="h_video" target="dec_box" parent="1">
