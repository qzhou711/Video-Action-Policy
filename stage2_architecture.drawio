        <mxCell id="adaln1" value="&lt;b&gt;AdaLN-Zero&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot; color=&quot;#991B1B&quot;&gt;LN(x)·(1+scale)+shift&lt;br&gt;cond→(shift,scale,gate)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#EF4444;fontSize=10;arcSize=10;" vertex="1" parent="1">
